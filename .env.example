# ─── Strava ────────────────────────────────────────────────────────────────
# Create an API app at https://www.strava.com/settings/api
# then run:  python scripts/strava_auth.py
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REFRESH_TOKEN=your_refresh_token   # obtained via strava_auth.py

# ─── Garmin Connect ─────────────────────────────────────────────────────────
# No credentials needed here. Authenticate once via browser:
#   playwright install chromium
#   python scripts/garmin_auth.py
#
# Session cookies are saved to ~/.spin-sync-garmin-session.json.
# Override the path with:
# GARMIN_SESSION_FILE=/custom/path/garmin-session.json

# ─── Optional tuning ────────────────────────────────────────────────────────
# How far back to look on the very first run (seconds). Default: 6 hours.
# LOOKBACK_SECONDS=21600

# Max gap between ICG and watch start times for activity matching (seconds). Default: 600 (10 min).
# TIME_MATCH_TOLERANCE_S=600

# Path to the state file that tracks already-synced activity IDs.
# Default: ~/.spin-sync-state.json
# STATE_FILE=/custom/path/to/state.json
